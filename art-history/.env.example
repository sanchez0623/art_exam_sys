# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Notion (for content sync)
NOTION_API_KEY=secret_your_notion_integration_token
NOTION_ARTICLES_DATABASE_ID=your-notion-database-id
# Secret used to authorize POST /api/notion-sync (generate a random string, e.g. openssl rand -hex 32)
NOTION_SYNC_SECRET=your-random-secret
